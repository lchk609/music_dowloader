import {
    VerticalBox,
    HorizontalBox,
    ScrollView,
    Button,
    LineEdit,
} from "std-widgets.slint";
import { SongItem, Song } from "components/song-item.slint";
import { Sidebar } from "components/side-bar.slint";
import { AddPlaylist } from "dialog/add-playlist.slint";
import { SettingDialog } from "dialog/settings.slint";
import { Playlist } from "structs/playlist.slint";
import { AppLogic } from "globals/callbacks.slint";
import { DialogType } from "enums/dialog-type.slint";
import { Settings } from "structs/settings.slint";

export component App inherits Window {
    preferred-width: 1000px;
    min-width: 1000px;
    min-height: 1000px;
    title: "Music Downloader";

    in-out property <string> url: "";
    in-out property <[Playlist]> playlists: [];
    in-out property <[Song]> songs: [];
    in-out property <Settings> settings;
    callback open_dialog(DialogType);

    add-playlist-popup := AddPlaylist { }

    setting-dialog := SettingDialog { settings: settings; }

    open_dialog(dialog) => {
        if (dialog == DialogType.Settings) {
            setting-dialog.visible = true;
            add-playlist-popup.visible = false;
        } else if (dialog == DialogType.CreatePlaylist) {
            add-playlist-popup.visible = true;
            setting-dialog.visible = false;
        }
    }

    HorizontalBox {
        spacing: 20px;
        padding: 20px;
        width: 100%;
        min-width: 2000px;

        Sidebar {
            playlists: root.playlists;
            open_dialog(dialog) => {
                open_dialog(dialog);
            }
        }

        VerticalBox {
            spacing: 20px;

            HorizontalBox {
                spacing: 10px;

                LineEdit {
                    placeholder-text: "paste the url";
                    horizontal-stretch: 1;
                    input-type: InputType.text;
                    height: 40px;
                    edited(value) => {
                        root.url = value;
                    }
                }

                Button {
                    text: "download";
                    width: 120px;
                    accessible-role: AccessibleRole.none;
                    height: 40px;
                    clicked => {
                        AppLogic.download_clicked(root.url);
                    }
                }
            }

            ScrollView {
                vertical-stretch: 1;

                VerticalBox {
                    spacing: 15px;
                    padding: 5px;

                    for song in root.songs: SongItem {
                        title: song.title;
                        is_downloading: song.is_downloading;
                    }
                }
            }
        }
    }
}

export { AppLogic }
