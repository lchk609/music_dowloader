import { VerticalBox, Button, ScrollView } from "std-widgets.slint";
import { PlaylistItem } from "playlist-item.slint";
import { AddPlaylist } from "add-playlist-dialog.slint";
import { Playlist } from "../structs/playlist.slint";
export component Sidebar inherits Rectangle {
    in property <[Playlist]> playlists;
    in property <string> name;
    callback open_add_playlist_dialog();
    callback playlist_selected(string);
    callback refresh_playlist(string);
    callback delete_playlist(string);

    width: 300px;
    border-width: 2px;
    border-color: #444;
    border-radius: 20px;

    VerticalBox {
        padding: 16px;
        spacing: 16px;

        Text {
            text: "tracked playlists";
            font-size: 18px;
        }

        Button {
            text: "add playlist";
            height: 40px;
            icon: @image-url("../assets/icon-plus.svg");
            icon-size: 16px;

            clicked => {
                root.open_add_playlist_dialog();
            }
        }

        ScrollView {

            VerticalBox {
                spacing: 8px;

                for pl in playlists : PlaylistItem {
                    playlist: pl;
                    manage_playlist_display(playlist_id) => {
                        playlist_selected(playlist_id);
                    }
                    refresh_playlist(playlist_id) => {
                        refresh_playlist(playlist_id);
                    }
                    delete_playlist(playlist_id) => {
                        delete_playlist(playlist_id);
                    }
                }
            }
        }

        Button {
            text: "settings";
            height: 40px;
        }
    }
}